-- pjsekai-overlay-APPEND {version} by TootieJin + ぴぃまん + 名無し｡ ----------------------------------

@Root
--dialog:PED File Path,file="";Text Language,text_lang={text_lang};Detailed Stats/chk,detail_stat={detail_stat}
--track0:Offset,-99999.99,99999.99,{offset},0.01
--track1:Cache,0,1,{cache},1
--check0:Watermark,{watermark}

local font = "{font}"
if obj.track1 ~= 1 or not PED_DATA or PED_DATA.file ~= file then
  debug_print("[pjsekai-overlay] Loading ped data in " .. file)
  local time = os.clock()
  MAX_w, MAX_h = obj.getinfo("image_max")
  PED_DATA = {}
  PED_DATA.frames = {}
  PED_DATA.combo = {}
  PED_DATA.event = {}
  PED_DATA.life = {}
  PED_DATA.path = nil
  PED_DATA.version = nil
  PED_DATA.version_status = "none"
  PED_DATA.enUI = false
  PED_DATA.b = false
  PED_DATA.file = file
  PED_DATA.cache_number = obj.track1
  PED_DATA.current = nil
  PED_DATA.previous = nil
  PED_DATA.next = nil
  PED_DATA.burst = nil
  PED_DATA.skill = nil
  local fp, err = io.open(file, "r")
  if fp then
    PED_DATA.loaded = "invalid"
    for line in fp:lines() do
      local header, data = string.match(line, "([a-z]+)|(.+)")
      if header ~= nil then
        PED_DATA.loaded = "ok"
        if header == "d" then -- Data
          local nmatch = {string.match(data, "([%-0-9.]+):([%-0-9.]+):([%-0-9.]+):([%-0-9.]+):([%-0-9.]+):([a-z]+):([%-0-9.]+)")}
          PED_DATA.frames[#PED_DATA.frames + 1] = {
            time = tonumber(nmatch[1]),
            score = tonumber(nmatch[2]),
            offset = tonumber(nmatch[3]),
            width = tonumber(nmatch[4]),
            widthv1 = tonumber(nmatch[5]),
            rank = nmatch[6],
            combo = tonumber(nmatch[7])
          }
        elseif header == "c" then -- Combo
          local nmatch = {string.match(data, "([%-0-9.]+):([%-0-9.]+)")}
          PED_DATA.combo[#PED_DATA.combo + 1] = {
            time = tonumber(nmatch[1]),
            combo = tonumber(nmatch[2])
          }
        elseif header == "s" then -- Skill
          local nmatch = {string.match(data, "([%-0-9.]+):([%-0-9.]+):([%-0-9.]+)")}
          PED_DATA.event[#PED_DATA.event + 1] = {
            time = tonumber(nmatch[1]),
            effect = tonumber(nmatch[2]),
            level = tonumber(nmatch[3])
          }
        elseif header == "l" then -- Life (heal)
          local nmatch = {string.match(data, "([%-0-9.]+):([%-0-9.]+)")}
          PED_DATA.life[#PED_DATA.life + 1] = {
            time = tonumber(nmatch[1]),
            life = tonumber(nmatch[2])
          }
        elseif header == "p" then -- Path
          PED_DATA.path = data
        elseif header == "e" then -- English UI
          PED_DATA.enUI = data == "true"
        elseif header == "b" then -- Blacklisted
          PED_DATA.b = data == "true"
        elseif header == "v" then -- Version
          PED_DATA.version = data
        elseif header == "i" then -- Initial Life
          PED_DATA.initial_life = tonumber(data)
        end
      end
    end
    debug_print("[pjsekai-overlay] Successfully loaded ped data")
    debug_print("[pjsekai-overlay] Time (s): " .. os.clock() - time)
    debug_print("[pjsekai-overlay] Version: " .. PED_DATA.version)
    debug_print("[pjsekai-overlay] # of frames: " .. #PED_DATA.frames)
    debug_print("[pjsekai-overlay] # of combo bursts: " .. #PED_DATA.combo)
    fp:close()
  else
    PED_DATA.loaded = "cannot_open"
    debug_print("[pjsekai-overlay] " .. err)
    debug_print("[pjsekai-overlay] Couldn't open ped data file")
  end
end
if (PED_DATA.version == "{version}" or "{version}" == "0.0.0") and (MAX_w >= 2560 and MAX_h >= 2048) then
  OFFSET = obj.track0
  PED_DATA.current = {
    time = 0,
    score = 0,
    offset = 0,
    width = 0,
    widthv1 = 0,
    rank = "d",
    combo = 0,
  }
  PED_DATA.previous = {
    time = 0,
    score = 0,
    offset = 0,
    width = 0,
    widthv1 = 0,
    rank = "d",
    combo = 0,
  }
  PED_DATA.burst = {
    time = 0,
    combo = 0,
  }
  PED_DATA.skill = {
    time = 0,
    effect = 0,
    level = 0,
  }
  PED_DATA.life_current = {
    time = 0,
    life = 0,
  }
  for i = #PED_DATA.frames, 1, -1 do
    local score = PED_DATA.frames[i]
    if (score.time * obj.framerate) < (obj.frame - OFFSET) then
      PED_DATA.current = score
      break
    end
  end
  if PED_DATA.current and PED_DATA.current.time and PED_DATA.current.time > 0 then
    for i = #PED_DATA.frames, 1, -1 do
      local previous = PED_DATA.frames[i]
      if previous.time < PED_DATA.current.time then
        PED_DATA.previous = {
          time = previous.time,
          score = previous.score,
          offset = previous.offset,
          width = previous.width,
          widthv1 = previous.widthv1,
          rank = previous.rank,
          combo = previous.combo,
        }
        break
      end
    end
  end
  if PED_DATA.current and PED_DATA.current.time then
    for i = 1, #PED_DATA.frames do
      local next = PED_DATA.frames[i]
      if next.time > PED_DATA.current.time then
        PED_DATA.next = next
        break
      end
    end
  else
    PED_DATA.next = PED_DATA.frames[1]
  end
  for i = #PED_DATA.combo, 1, -1 do
    local combo = PED_DATA.combo[i]
    if (combo.time * obj.framerate) < (obj.frame - OFFSET) then
      PED_DATA.burst = combo
      break
    end
  end
  for i = #PED_DATA.event, 1, -1 do
    local event = PED_DATA.event[i]
    if (event.time * obj.framerate) < (obj.frame - OFFSET) then
      PED_DATA.skill = event
      break
    end
  end
  for i = #PED_DATA.life, 1, -1 do
    local life = PED_DATA.life[i]
    if (life.time * obj.framerate) < (obj.frame - OFFSET) then
      PED_DATA.life_current = life
      break
    end
  end
  PED_DATA.version_status = "ok"
else
  obj.setfont(font, 32)
  if PED_DATA.loaded == "cannot_open" then
    if text_lang == 1 then
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "ped file unable to be opened!"
      )
    else
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "pedファイルを開くことができません！"
      )
    end
  elseif PED_DATA.loaded == "invalid" then
    if text_lang == 1 then
      obj.load(
      "text",
      "<s32,"..font..",B>(! ERROR !)\n<s>"..
      "Unable to read ped file!\n"..
      "- Regenerate pjsekai-overlay."
    )
    else
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "pedファイルを読み取れません！\n"..
        "- pjsekai-overlayを再生成してください。"
      )
    end
  elseif PED_DATA.version == nil then
    if text_lang == 1 then
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "Version of the ped file is not set!\n"..
        "- Regenerate pjsekai-overlay."
      )
    else
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "pedファイルのバージョンが設定されていません！\n"..
        "- pjsekai-overlayを再生成してください。"
      )
    end
  elseif MAX_w < 2560 or MAX_h < 2048 then
    if text_lang == 1 then
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "Max image size is too low!\n"..
        "[Required size: 2560x2048]\n\n"..
        "- Change the max image size in AviUtl. (File > SETTINGS > System > Max resolution)"
      )
    else
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "最大画像サイズが小さすぎます！\n"..
        "[必要なサイズ: 2560x2048]\n\n"..
        "- AviUtlの最大画像サイズを変更してください。(ファイル > 設定 > システム > 最大画像サイズ)"
      )
    end
  else
    if text_lang == 1 then
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "The version of the file is different!\n"..
        "[.obj: {version}, .ped: "..PED_DATA.version.."]\n\n"..
        "- <s32,"..font..",B>If .obj is up to date:<s> Regenerate pjsekai-overlay.\n"..
        "- <s32,"..font..",B>If .ped is up to date:<s> Regenerate object file. (Open AviUtl, then pjsekai-overlay-APPEND)\n"..
        "<s32,"..font..",B>DO NOT RENAME ped VERSION!<s>"
      )
    else
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "ファイルとのバージョンが違います！\n"..
        "[.obj: {version}, .ped: "..PED_DATA.version.."]\n\n"..
        "- <s32,"..font..",B>.objが最新の場合:<s> pjsekai-overlayを再生成してください。\n"..
        "- <s32,"..font..",B>.pedが最新の場合:<s> オブジェクトファイルを再生成してください。(AviUtlを開き、pjsekai-overlay-APPENDを実行)\n"..
        "<s32,"..font..",B>pedバージョンの名前を変更しないでください！<s>"
      )
    end
  end
  obj.draw()
  PED_DATA.version_status = "ng"
end

if PED_DATA.b then
  if text_lang == 1 then
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "pjsekai-overlay isn't generated due to the server/charter being in the blacklist."
      )
    else
      obj.load(
        "text",
        "<s32,"..font..",B>(! ERROR !)\n<s>"..
        "サーバーまたは譜面作成が禁止リストに登録されているため、pjsekai-overlay が生成されません。"
      )
    end
  obj.draw()
end

if obj.check0 and PED_DATA.version_status == "ok" then
  obj.setfont(font, 100)
  obj.load(
      "text",
      "<s100,"..font..",B>※TootieJin氏の「pjsekai-overlay-APPEND」を使用\n"..
      "※Made with「pjsekai-overlay-APPEND」by TootieJin\n"..
      "............................................................................<s>"
  )
  obj.draw(-614 - ((obj.screen_w/2) - (1920/2)), 513 + ((obj.screen_h/2) - (1080/2)), 0, 0.24, 0.5)
end
if detail_stat == 1 and PED_DATA.version_status == "ok" and not obj.getinfo("saving") then
  obj.setfont(font, 100)
  if text_lang == 0 then
    obj.load(
      "text",
      "<s100,"..font..",B>"..
      "--------------------------------------------------------------------------------------------\n"..
      "※詳細な統計情報 (v"..PED_DATA.version.."):\n"..
      "現在のスコアからのフレーム: "..string.format("%.2f", (obj.frame - OFFSET) - (PED_DATA.current.time * obj.framerate)).." ("..string.format("%.6f", (obj.time - (OFFSET / obj.framerate)) - (PED_DATA.current.time)).."秒)\n"..
      "現在のスキルからのフレーム: "..string.format("%.2f", (obj.frame - OFFSET) - (PED_DATA.skill.time * obj.framerate)).." ("..string.format("%.6f", (obj.time - (OFFSET / obj.framerate)) - (PED_DATA.skill.time)).."秒)\n"..
      "現在のコンボ効果からのフレーム: "..string.format("%.2f", (obj.frame - OFFSET) - (PED_DATA.burst.time * obj.framerate)).." ("..string.format("%.6f", (obj.time - (OFFSET / obj.framerate)) - (PED_DATA.burst.time)).."秒)\n"..
      "次のスコアまでのフレーム: "..string.format("%.2f", (PED_DATA.next.time * obj.framerate) - ((obj.frame - OFFSET))).." ("..string.format("%.6f", ((PED_DATA.next.time) - (obj.time - (OFFSET / obj.framerate)))).."秒)\n"..
      "表示されている（実際の）スコア差: "..PED_DATA.current.offset.." ("..PED_DATA.current.score - PED_DATA.previous.score..")\n"..
      "フレーム対時間の計算差（約0である必要があります）: "..string.format("%.6f", (obj.frame / obj.framerate) - obj.time).."\n"..
      "※出力時にはこのテキストは表示されません。\n"..
      "--------------------------------------------------------------------------------------------<s>"
    )
  else
    obj.load(
      "text",
      "<s100,"..font..",B>"..
      "--------------------------------------------------------------------------------------------\n"..
      "※Detailed Stats (v"..PED_DATA.version.."):\n"..
      "Frame from current score: "..string.format("%.2f", (obj.frame - OFFSET) - (PED_DATA.current.time * obj.framerate)).." ("..string.format("%.6f", (obj.time - (OFFSET / obj.framerate)) - (PED_DATA.current.time)).."s)\n"..
      "Frame from current skill: "..string.format("%.2f", (obj.frame - OFFSET) - (PED_DATA.skill.time * obj.framerate)).." ("..string.format("%.6f", (obj.time - (OFFSET / obj.framerate)) - (PED_DATA.skill.time)).."s)\n"..
      "Frame from current combo burst: "..string.format("%.2f", (obj.frame - OFFSET) - (PED_DATA.burst.time * obj.framerate)).." ("..string.format("%.6f", (obj.time - (OFFSET / obj.framerate)) - (PED_DATA.burst.time)).."s)\n"..
      "Frame until next score: "..string.format("%.2f", (PED_DATA.next.time * obj.framerate) - ((obj.frame - OFFSET))).." ("..string.format("%.6f", ((PED_DATA.next.time) - (obj.time - (OFFSET / obj.framerate)))).."s)\n"..
      "Displayed (actual) score difference: "..PED_DATA.current.offset.." ("..PED_DATA.current.score - PED_DATA.previous.score..")\n"..
      "Frame vs. Time calculation difference (should be around 0): "..string.format("%.6f", (obj.frame / obj.framerate) - obj.time).."\n"..
      "※This text will not be shown when exporting.\n"..
      "--------------------------------------------------------------------------------------------<s>"
    )
  end
  obj.draw(-490 - ((obj.screen_w/2) - (1920/2)), 0, 0, 0.22, 0.8)
end
----------------------------------------------------------------
@Life
--track0:X-axis Boundary,0,9999,6000,1
--track1:LIFE,0,9999,{life},1
--track2:Skill Effect,0,2,{life_skill},1
--dialog:Overflow LIFE Bar/chk,overflow={overflow};Leading Zero/chk,lead_zero={lead_zero};Unlock LIFE Bar/chk,unlock_life={unlock_life}

local x_boundary = obj.track0
local life = obj.track1
local skill = obj.track2
if PED_DATA and PED_DATA.version_status == "ok" then
  local progress_skill = ((obj.frame - OFFSET) - (PED_DATA.skill.time * obj.framerate))

  local life_num = life
  if unlock_life == 0 then
    local life_heal = PED_DATA.life_current.life
    life_num = PED_DATA.initial_life + life_heal
  end

  local life_str = string.format("%d", life_num)
  local life_alpha = 1

  if lead_zero == 1 then
    life_str = string.format("%4d", life_num):gsub(" ", "n")
  end

  obj.setoption("drawtarget", "tempbuffer", x_boundary, math.ceil(600 * 1.5))
  obj.load("image", PED_DATA.path .. "/life/v3/bg.png")
  if skill >= 1 then
    if (PED_DATA.skill and PED_DATA.skill.effect == 1 and PED_DATA.skill.time > 0 and progress_skill <= 300) or skill == 2 then
      obj.effect("Shadow", "X", 0, "Y", 0, "Thickness", 100, "Diffusion", 100, "color", 0x6dffff)
      obj.draw(0, 0, 0, 1)
      obj.load("image", PED_DATA.path .. "/life/v3/bg.png")
    end
  end
  obj.draw(0, 0, 0, 1)

  if overflow == 1 and life_num > 1000 then
    obj.load("image", PED_DATA.path.."/life/v3/normal.png")
    obj.draw(0, 0, 0, 1, 0.7)
  end

  local life_name = ""
  if overflow == 1 and life_num > 1000 then
    life_alpha = (math.sin(obj.time * math.pi) + 1) * (1 / 2)
    life_num = life_num - 1000
    life_name = "overflow"
  elseif life_num <= 200 then
    life_name = "danger"
  else
    life_name = "normal"
  end

  -- Masking via file is a life-saver AviUtl2 where is it
  obj.load("image", PED_DATA.path.."/life/v3/"..life_name..".png")
  obj.effect("Mask", "X", -1635 + (life_num * 1.635), "Size", 2560, "name", "*" .. PED_DATA.path .. "/life/v3/mask.png")
  obj.draw(0, 0, 0, 1, life_alpha)

  for i = #life_str, 1, -1 do
    obj.load("image", PED_DATA.path .. "/life/v3/digit/s" .. string.sub(life_str, i, i) .. ".png")
    obj.draw(563 - (#life_str - i) * 127, -145, 0, 0.147)
  end
  for i = #life_str, 1, -1 do
    obj.load("image", PED_DATA.path .. "/life/v3/digit/" .. string.sub(life_str, i, i) .. ".png")
    obj.draw(563 - (#life_str - i) * 127, -145, 0, 0.147)
  end

  obj.copybuffer("obj", "tmp")
end
----------------------------------------------------------------
@Score
--track0:X-axis Boundary,0,9999,6000,1
--track1:Min Digit,1,99,{min_digit},1
--track2:Skill Effect,0,2,{score_skill},1
--check0:Animated Scoring,{anim_score}
--dialog:Animation Speed,speed={score_speed};WDS Animation/chk,wds_anim={wds_anim}

local x_boundary = obj.track0
local min_digit = obj.track1
local skill = obj.track2
local anim_score = obj.check0 and 1 or 0
if PED_DATA and PED_DATA.version_status == "ok" then
  local progress_frame = ((obj.frame - OFFSET) - (PED_DATA.current.time * obj.framerate))
  local progress_skill = ((obj.frame - OFFSET) - (PED_DATA.skill.time * obj.framerate))
  local progress_offset = math.min(1, (progress_frame / 30))

  obj.setoption("drawtarget", "tempbuffer", x_boundary, math.ceil(120 * 1.5))
  obj.load("image", PED_DATA.path.."/score/bg.png")
  if skill >= 1 then
    if (PED_DATA.skill and PED_DATA.skill.time > 0 and progress_skill <= 300) or skill == 2 then
      obj.effect("Shadow", "X", 0, "Y", 0, "Thickness", 100, "Diffusion", 50, "color", 0xd4ff5d)
      obj.draw(0, 0, 0, 0.2145)
      obj.load("image", PED_DATA.path.."/score/bg.png")
    end
  end
  obj.draw(0, 0, 0, 0.2145)

  local width = PED_DATA.current.width
  if anim_score == 1 then
    width = PED_DATA.current.width - (PED_DATA.current.width - PED_DATA.previous.width) * (1 - progress_offset)^3
  end

  -- -- 79, 35 / 532, 24
  obj.load("image", PED_DATA.path.."/score/bar.png")
  obj.effect("Mask", "X", width * 1650, "Size", 1650, "Type of mask", "Square", "Invert mask", 1)
  obj.draw(34, -3, 0, 0.2145)

  if PED_DATA.enUI then
    obj.load("image", PED_DATA.path.."/score/rank/txt/en/"..PED_DATA.current.rank..".png")
    obj.draw(-187, 35, 0, 0.34 * (22/130))
  else
    obj.load("image", PED_DATA.path.."/score/rank/txt/jp/"..PED_DATA.current.rank..".png")
    obj.draw(-187, 35, 0, 0.34 * (22/130))
  end

  if PED_DATA.current.time ~= 0 then
    obj.load("image", PED_DATA.path.."/score/rank/chr/"..PED_DATA.current.rank..".png")
    obj.draw(-188, -6, 0, 0.22)
  end

  obj.load("image", PED_DATA.path.."/score/fg.png")
  obj.draw(0, 0, 0, 0.2145)

  -- -127, 27, +22
  local score_str = ""
  local minusDigits = math.max(1, min_digit - 1)
  if anim_score == 1 then
    if PED_DATA.current.score < 0 then
      score_str = "-" .. string.format("%"..minusDigits..".0f", math.abs(PED_DATA.current.score - (PED_DATA.current.score - PED_DATA.previous.score) * (1 - progress_offset)^3)):gsub(" ", "n")
    else
      score_str = string.format("%"..min_digit..".0f", PED_DATA.current.score - (PED_DATA.current.score - PED_DATA.previous.score) * (1 - progress_offset)^3):gsub(" ", "n")
    end
  else
    if PED_DATA.current.score < 0 then
      score_str = "-" .. string.format("%"..minusDigits..".0f", math.abs(PED_DATA.current.score)):gsub(" ", "n")
    else
      score_str = string.format("%"..min_digit..".0f", PED_DATA.current.score):gsub(" ", "n")
    end
  end

  local score_len = #score_str

  if PED_DATA.current.time >= 0 and PED_DATA.current.combo > 0 and progress_frame <= 30 then
    local progress = math.min(1, (progress_frame / 12) * speed)
    local offset = PED_DATA.current.offset
    if PED_DATA.current.score ~= PED_DATA.previous.score and PED_DATA.current.offset == 0 then
      offset = PED_DATA.current.score - PED_DATA.previous.score
    end

    local diff = "+" .. string.format("%.0f", offset)
    if offset < 0 then
      diff = string.format("%.0f", offset)
    end
    local diff_len = #diff

    local diff_x = 26.25 + 47 * (1 - (0.9 ^ (progress * 12))) + 22 * (score_len - 8)
    local diff_y = 34
    local diff_alpha = 1.3 * (1 - (0.9 ^ (progress * 12)))

    if wds_anim == 1 then
      diff_x = -127
      diff_y = 68 - 15.5 * (1 - (0.9 ^ (progress * 12)))
    end

    for c = 1, diff_len do
      local digit = diff:sub(c, c)
      obj.load("image", PED_DATA.path.."/score/digit/s"..digit..".png")
      obj.draw(13.65 * (c - 1) + diff_x, diff_y, 0, 0.42, diff_alpha)
    end
    for c = 1, diff_len do
      local digit = diff:sub(c, c)
      obj.load("image", PED_DATA.path.."/score/digit/"..digit..".png")
      obj.draw(13.65 * (c - 1) + diff_x, diff_y, 0, 0.42, diff_alpha)
    end
  end

  for c = 1, score_len do
    local digit = score_str:sub(c, c)
    obj.load("image", PED_DATA.path.."/score/digit/s"..digit..".png")
    obj.draw(-127 + 22 * (c - 1), 26, 0, 0.65)
    obj.draw(-127 + 22 * (c - 1), 26, 0, 0.65)
  end
  for c = 1, score_len do
    local digit = score_str:sub(c, c)
    obj.load("image", PED_DATA.path.."/score/digit/"..digit..".png")
    obj.draw(-127 + 22 * (c - 1), 26, 0, 0.65)
    obj.draw(-127 + 22 * (c - 1), 26, 0, 0.65)
  end
  obj.copybuffer("obj", "tmp")
end
----------------------------------------------------------------
@Combo
--track0:X-axis Boundary,0,9999,6000,1
--track1:AP Combo,0,1,{ap},1
--track2:Combo Tag,0,1,{tag},1
--dialog:Show the last X digit(s),last_digit={last_digit};Animation Speed,speed={combo_speed};n00 Combo Burst/chk,combo_burst={combo_burst};Achievement Rate,achievement_rate="{achievement_rate}"

local x_boundary = obj.track0
local ap = obj.track1
local tag = obj.track2
local function convertToNumber(s)
  return s:match("([%-0-9.]+)")
end
local function endsWith(s, suffix)
  return s:sub(-#suffix) == suffix
end
local achievement_value = tonumber(convertToNumber(achievement_rate)) or 0
if PED_DATA and PED_DATA.version_status == "ok" then
  local ap_alpha = math.min(1, (math.sin(obj.time * math.pi * 4/3) + 1) * (1 / 2))
  local progress_frame = ((obj.frame - OFFSET) - (PED_DATA.current.time * obj.framerate))
  local progress_offset = math.min(1, (progress_frame / 30))
  obj.setoption("drawtarget", "tempbuffer", x_boundary, 400)

  if achievement_value ~= 0 then
    local achievement_str = string.format("%8.4f", (PED_DATA.current.combo / PED_DATA.frames[#PED_DATA.frames].combo) * achievement_value) .. "%"
    if endsWith(achievement_rate, "+") then
      achievement_str = string.format("%8.4f", ((PED_DATA.current.combo - ((PED_DATA.current.combo - PED_DATA.previous.combo) * (1 - progress_offset)^3)) / PED_DATA.frames[#PED_DATA.frames].combo) * achievement_value) .. "%"
    elseif endsWith(achievement_rate, "-") then
      achievement_str = string.format("%8.4f", achievement_value) .. "%"
    end

    local shift_period_x = 0
    for i = 1, #achievement_str do
      local digit = achievement_str:sub(i, i)
      if digit ~= " " then
        local shift = -(#achievement_str / 2) + (i + 1) - 0.5
        local shift_period_y = 0
        local shift_small_x = 0
        local shift_small_y = 0
        local size = 0.23

        if digit == "." then
          shift_period_x = shift_period_x - 6
          shift_period_y = 10 -- (!!) this variablle is different in v1!
        end
        if achievement_str:sub(i-1, i-1) == "." then
          shift_period_x = shift_period_x - 6
        end
        if i >= #achievement_str - 2 then
          shift = shift - (0.5 * (i - (#achievement_str - 2)))
          shift_small_x = -5
          shift_small_y = 7
          size = 0.115
        end
        if digit == "%" then
          shift = shift + 0.1
        end

        if ap == 1 then
          obj.load("image", PED_DATA.path.."/combo/b"..digit..".png")
          obj.setoption("blend", 0)
          obj.draw(shift * 23.65 + shift_period_x + shift_small_x, -125 + shift_period_y + shift_small_y, 0, size, ap_alpha)
          obj.load("image", PED_DATA.path.."/combo/p"..digit..".png")
        else
          obj.load("image", PED_DATA.path.."/combo/n"..digit..".png")
        end
        obj.draw(shift * 23.65 + shift_period_x + shift_small_x, -125 + shift_period_y + shift_small_y, 0, size)
      end
    end
  end

  if PED_DATA.current.combo ~= 0 then
    if tag == 1 then
      if ap == 1 then
        obj.load("image", PED_DATA.path.."/combo/pe.png")
        obj.draw(0, -70, 0, 0.67, ap_alpha)
      end
      if ap == 1 then
        obj.load("image", PED_DATA.path.."/combo/pt.png")
      else
        obj.load("image", PED_DATA.path.."/combo/nt.png")
      end
      obj.draw(0, -67, 0, 0.67)
    end

    local combo_str = tostring(PED_DATA.current.combo)
    local combo_burst_str = tostring(PED_DATA.burst.combo)

    local progress = progress_frame * speed
    local progress_burst = ((obj.frame - OFFSET) - (PED_DATA.burst.time * obj.framerate)) * speed

    if progress < 1 and PED_DATA.previous.combo ~= 0 then
      progress = ((obj.frame - OFFSET) - (PED_DATA.previous.time * obj.framerate)) * speed
    end

    for i = 1, #combo_str do
      if #combo_str - last_digit < i then
        local digit = combo_str:sub(i, i)
        local shift = -(#combo_str / 2) + i - 0.5
        local shift_fax = math.min(1, (progress / 8) * 0.5 + 0.5)

        if ap == 1 then
          obj.load("image", PED_DATA.path.."/combo/b"..digit..".png")
          obj.setoption("blend", 0)
          obj.draw(shift * 72 * shift_fax, 0, 0, 0.70 * shift_fax, ap_alpha)
          obj.load("image", PED_DATA.path.."/combo/p"..digit..".png")
        else
          obj.load("image", PED_DATA.path.."/combo/n"..digit..".png")
        end
        obj.draw(shift * 72 * shift_fax, 0, 0, 0.70 * shift_fax)
      end
    end
    obj.setoption("blend", 1)
    if progress < 14 then
      for i = 1, #combo_str do
        if #combo_str - last_digit < i then
          local digit = combo_str:sub(i, i)
          local shift = -(#combo_str / 2) + i - 0.5
          local shift_fax = (progress / 8) * 0.5 + 0.5
          local alpha = (progress / 14) * -1 + 1

          if ap == 1 then
            obj.load("image", PED_DATA.path.."/combo/b"..digit..".png")
            obj.setoption("blend", 0)
            obj.draw(shift * 72 * shift_fax, 0, 0, 0.70 * shift_fax, ap_alpha * alpha)
            obj.load("image", PED_DATA.path.."/combo/p"..digit..".png")
            if progress > 8 and progress < 11 then
              obj.effect("Glow", "Strength",  progress, "Blur", 5)
              obj.effect("Light", "Strength",  progress * 6.5, "Backlight", 1)
            elseif progress >= 11 and progress < 14 then
              obj.effect("Glow", "Strength",  2.5 * (1 - (progress - 13) / 0.5), "Blur", 5)
              obj.effect("Light", "Strength",  15 * (1 - (progress - 13) / 0.5), "Backlight", 1)
            end
          else
            obj.load("image", PED_DATA.path.."/combo/b"..digit..".png")
            obj.setoption("blend", 0)
            obj.draw(shift * 72 * shift_fax, 0, 0, 0.70 * shift_fax, 0)
            obj.load("image", PED_DATA.path.."/combo/n"..digit..".png")
            if progress > 8 and progress < 11 then
              obj.effect("Glow", "Strength",  progress, "Blur", 5)
              obj.effect("Light", "Strength",  progress * 6.5, "Backlight", 1)
            elseif progress >= 11 and progress < 14 then
              obj.effect("Glow", "Strength",  2.5 * (1 - (progress - 13) / 0.5), "Blur", 5)
              obj.effect("Light", "Strength",  15 * (1 - (progress - 13) / 0.5), "Backlight", 1)
            end
          end
          obj.draw(shift * 72 * shift_fax, 0, 0, 0.70 * shift_fax, alpha)
        end
      end
    end
    if progress_burst < 14 and combo_burst == 1 then
      for i = 1, #combo_burst_str do
        if #combo_burst_str - last_digit < i then
          local digit = combo_burst_str:sub(i, i)
          local shift = -(#combo_burst_str / 2) + i - 0.5
          local shift_fax_burst = 1.75 - (1.077 - (progress_burst / 14))^3
          local alpha_burst = ((progress_burst + 6) / 20) * -1 + 1
          if progress_burst < 1 then
            shift_fax_burst = 1.75
            alpha_burst = 0.7
          end

          if ap == 1 then
            obj.load("image", PED_DATA.path.."/combo/b"..digit..".png")
            obj.setoption("blend", 0)
            obj.draw(shift * 72 * shift_fax_burst, 0, 0, 0.70 * shift_fax_burst, ap_alpha * alpha_burst)
            obj.load("image", PED_DATA.path.."/combo/p"..digit..".png")
          else
            obj.load("image", PED_DATA.path.."/combo/b"..digit..".png")
            obj.setoption("blend", 0)
            obj.draw(shift * 72 * shift_fax_burst, 0, 0, 0.70 * shift_fax_burst, 0)
            obj.load("image", PED_DATA.path.."/combo/n"..digit..".png")
          end
          obj.draw(shift * 72 * shift_fax_burst, 0, 0, 0.70 * shift_fax_burst, alpha_burst)
        end
      end
    end
  end
  obj.setoption("blend", 0)
  obj.copybuffer("obj", "tmp")
end
----------------------------------------------------------------
@Skill
--dialog:Icon Filename,file="";Animation Speed,speed={skill_speed}

--[[
local function get_images_in_path(path)
  local filenames = {}
  debug_print("[pjsekai-overlay] Searching for images in path: " .. path)
  if not path or path == "" then
    debug_print("[pjsekai-overlay] Path is empty: " .. path)
    return filenames
  end
  local safe_path = path:gsub("\"", "\\\"")
  -- Use cmd /c to ensure compatibility with Windows when using io.popen on Lua 5.1
  -- Add stderr redirection to suppress errors when directory is not accessible or contains special files
  local command = 'cmd /c dir "' .. safe_path .. '" /b /a:-d 2>nul'
  local proc = io.popen(command)
  if proc then
    for line in proc:lines() do
      if line ~= "" and line:sub(-4) == ".png" then
        filenames[#filenames + 1] = line
      end
    end
    proc:close()
  end
  debug_print("[pjsekai-overlay] Found " .. #filenames .. " images in path: " .. path)
  return filenames
end

doesn't work :')
--]]

local function split(str, sep)
  local result = {}
  local from = 1
  local delim_from, delim_to = string.find(str, sep, from)
  while delim_from do
    table.insert(result, string.sub(str, from, delim_from - 1))
    from = delim_to + 1
    delim_from, delim_to = string.find(str, sep, from)
  end
  table.insert(result, string.sub(str, from))
  return result
end

if PED_DATA and PED_DATA.version_status == "ok" then
  local progress_frame = ((obj.frame - OFFSET) - (PED_DATA.skill.time * obj.framerate))
  local skilltype = {"Score", "Life", "Skill"}
  --[[
  if cache ~= 1 or not Profile then
    Profile = get_images_in_path(PED_DATA.path.."/skill/profile/")
  end
  --]]

  local skill_str = ""
  if skilltype[PED_DATA.skill.effect + 1] == "Score" then
    skill_str = tostring(100 + (5 * ((PED_DATA.skill.level-1) + math.max(0, (PED_DATA.skill.level-3))))) .. "%"
  elseif skilltype[PED_DATA.skill.effect + 1] == "Life" then
    skill_str = tostring(350 + (50 * (PED_DATA.skill.level - 1)))
  elseif skilltype[PED_DATA.skill.effect + 1] == "Skill" then
    skill_str = tostring(5.5 + (0.5 * (PED_DATA.skill.level - 1))) .. "s"
  end

  if PED_DATA.skill.time > 0 then
    obj.setoption("drawtarget", "tempbuffer", 600, 136)
    local progress = progress_frame * speed

    local shift_fax = math.max(0, 1 - (1 - math.min(1, (progress_frame / 12) * speed)) ^ 2)
    if progress >= 19 then
      shift_fax = math.min(1, - ( - (1 - math.min(1, ((progress_frame / 12) * speed) - 19)) ^ 2))
    end

    local shift_text1 = 0
    local shift_alpha1 = 1
    if progress >= 9.5 then
      shift_text1 = math.max(0, 1 - (1 - math.min(1, 2 * ((progress_frame / 12) * speed) - 19)) ^ 2)
      shift_alpha1 = math.min(1, - ( - (1 - math.min(1, 2 * ((progress_frame / 12) * speed) - 19)) ^ 2))
    end

    local shift_text2 = -1
    local shift_alpha2 = 0
    if progress >= 10 then
      shift_text2 = -math.min(1, - ( - (1 - math.min(1, 2 * ((progress_frame / 12) * speed) - 20)) ^ 2))
      shift_alpha2 = math.max(0, math.min(1, 1 - (1 - math.min(1, 2 * ((progress_frame / 12) * speed) - 20)) ^ 2))
    end

    obj.load("image", PED_DATA.path.."/skill/v3/"..skilltype[PED_DATA.skill.effect + 1].."-UP.png")
    obj.draw(0 + 64 * shift_fax, 0, 0, 1, shift_fax)

    local profile = split(file, ",")
    local profile_filename
    if #profile > 0 then
      -- initialize selection pool and last_time on first use
      PED_DATA.skill = PED_DATA.skill or {}
      if not PED_DATA.skill._profile_pool then
        PED_DATA.skill._profile_pool = {}
        for i = 1, #profile do table.insert(PED_DATA.skill._profile_pool, i) end
      end
      -- when time updates, pick a random index from the pool without duplication
      if PED_DATA.skill._last_time ~= PED_DATA.skill.time then
        if #PED_DATA.skill._profile_pool == 0 then
          -- refill pool when exhausted
          for i = 1, #profile do table.insert(PED_DATA.skill._profile_pool, i) end
        end
        local pick_pos = math.random(1, #PED_DATA.skill._profile_pool)
        local picked = PED_DATA.skill._profile_pool[pick_pos]
        table.remove(PED_DATA.skill._profile_pool, pick_pos)
        PED_DATA.skill._selected_profile_index = picked
        PED_DATA.skill._last_time = PED_DATA.skill.time
      end
      local profile_index = PED_DATA.skill._selected_profile_index or 1
      profile_filename = profile[profile_index]
    end

    if file then
      obj.load("image", PED_DATA.path.."/skill/profile/"..profile_filename)
      obj.draw(-97 + 64 * shift_fax, 14.5, 0, 0.57, shift_fax)
    end

    obj.load("image",PED_DATA.path.."/skill/v3/digit/Lv.png")
    obj.draw(120 + 64 * shift_fax - 10 * shift_text1, 31.5, 0, 1, shift_fax * shift_alpha1)
    obj.load("image",PED_DATA.path.."/skill/v3/digit/"..tostring(PED_DATA.skill.level)..".png")
    obj.draw(167 + 64 * shift_fax - 10 * shift_text1, 31, 0, 0.82, shift_fax * shift_alpha1)

    local shift_start_x = 0
    local shift_after_x1 = 0
    local shift_after_x2 = 0
    local shift_period_x = 0
    local specials = 0

    for i = #skill_str, 1, -1 do
      local digit = string.sub(skill_str, i, i)
      local digit_after = string.sub(skill_str, i + 1, i + 1)

      -- specials
      local shift_size = 1
      if digit == "%" or digit == "s" then
        shift_start_x = shift_start_x - 4
        shift_size = 1/0.78
      end

      if digit_after == "%" or digit_after == "s" then
        shift_after_x1 = shift_after_x1 - 29
        specials = specials + 1
      end

      if digit == "." then
        shift_period_x = shift_period_x + 8.5
      end

      if digit_after == "." then
        shift_after_x2 = shift_after_x2 - 17.5
        specials = specials + 1
      end

      obj.load("image", PED_DATA.path .. "/skill/v3/digit/" .. digit .. ".png")
      obj.draw(167 - 27.5 * (#skill_str - i - specials) + shift_period_x + shift_start_x + shift_after_x1 + shift_after_x2 + 64 * shift_fax - 10 * shift_text2, 33, 0, 0.78 * shift_size, shift_fax * shift_alpha2)
    end

    obj.copybuffer("obj", "tmp")
  end
end
----------------------------------------------------------------
@Judgement
--track0:Judge Type,1,10,{judge},1
--dialog:Animation Speed,speed={judge_speed}

local judge = obj.track0
if PED_DATA and PED_DATA.version_status == "ok" then
  if PED_DATA.current.time > 0 then
    obj.setoption("drawtarget", "tempbuffer", obj.screen_w, 82)
    local progress = ((obj.frame - OFFSET) - (PED_DATA.current.time * obj.framerate)) * speed

    if progress < 2 then
      obj.load("image", PED_DATA.path.."/judge/v3/"..judge..".png")
      obj.draw(0, 0, 0, (2/3), 0)
    elseif progress < 5 then
      obj.load("image", PED_DATA.path.."/judge/v3/"..judge..".png")
      obj.draw(0, 0, 0, (2/3) - (-1.45 + (progress / 4)) ^ 4 * (2/3))
    elseif progress < 20 then
      obj.load("image", PED_DATA.path.."/judge/v3/"..judge..".png")
      obj.draw(0, 0, 0, (2/3))
    end
  obj.copybuffer("obj", "tmp")
  end
end
----------------------------------------------------------------
@Auto
if PED_DATA and PED_DATA.version_status == "ok" then
  obj.setoption("drawtarget", "tempbuffer", 330, 74)
  local auto_alpha = math.max(0, math.sin(math.fmod((obj.time - 1.6) / 1.25, 1.2) * math.pi))
  if PED_DATA.enUI then
    if obj.time - 1.6 >= 0 then
      obj.load("image", PED_DATA.path.."/autolive-en.png")
      obj.draw(0, 0, 0, 1, auto_alpha)
    end
  else
    if obj.time - 1.6 >= 0 then
      obj.load("image", PED_DATA.path.."/autolive.png")
      obj.draw(0, 0, 0, 1, auto_alpha)
    end
  end
  obj.copybuffer("obj", "tmp")
end
